# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Database configuration (MySQL/MariaDB via PDO)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=myloc_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# JWT configuration
# Use a strong random string of at least 32 characters in production.
JWT_SECRET=change_me_in_production_please_use_a_long_random_string
JWT_EXPIRY=3600

# CORS: comma-separated list of allowed frontend origins.
# No spaces around commas. Do not use * in production.
ALLOWED_ORIGINS=http://localhost:3000,https://ahcene-sa.github.io

# Login rate limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=900

# Application environment: development | production
APP_ENV=development
